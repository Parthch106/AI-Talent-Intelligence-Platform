# ============================================================
# AI Talent Intelligence Platform — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# The server reads these via os.environ at startup.
# IMPORTANT: Never commit .env file to version control!

# ============================================================
# Django Core
# ============================================================
DJANGO_ENV=development
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================================
# Database (PostgreSQL)
# ============================================================
POSTGRES_DB=ai_talent_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-db-password-here
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ============================================================
# LLM Resume Parser (GitHub OpenAI API)
# ============================================================
# IMPORTANT: Use a CLASSIC token (not fine-grained) from https://github.com/settings/tokens
# Fine-grained tokens do NOT work with GitHub Models AI API
# Get your token from: https://github.com/settings/tokens
# Required: Generate a "Classic" token with no specific scopes
# Endpoint used: https://models.inference.ai.azure.com
# Model: gpt-4o-mini
GITHUB_TOKEN=your-github-token-here

# Set to true to activate the LLM parser (requires CLASSIC token)
# Set to false to use the regex fallback (SimpleResumeParser)
USE_LLM_PARSER=false

# ============================================================
# Seed Data Passwords (Development Only)
# ============================================================
# These are used by the seed_data management command.
# Change these in production to secure values!
SEED_ADMIN_PASSWORD=adminpassword
SEED_MANAGER_PASSWORD=managerpassword
SEED_INTERN_PASSWORD=internpassword

# ============================================================
# CORS Settings
# ============================================================
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ============================================================
# JWT Settings
# ============================================================
# IMPORTANT: Must be at least 32 bytes (64 hex characters) for HS256
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Or leave empty and one will be generated automatically (not persistent)
JWT_SECRET_KEY=
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440

# ============================================================
# File Storage
# ============================================================
MEDIA_ROOT=media
MEDIA_URL=/media/

# ============================================================
# Email (optional)
# ============================================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
