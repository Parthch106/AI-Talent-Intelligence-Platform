# ============================================================
# AI Talent Intelligence Platform — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# The server reads these via os.environ at startup.

# ============================================================
# Django
# ============================================================
SECRET_KEY=your-django-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================================
# Database (PostgreSQL)
# ============================================================
DB_NAME=talent_intelligence_db
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# ============================================================
# LLM Resume Parser (GitHub OpenAI API)
# ============================================================
# Get your token from: https://github.com/settings/tokens
# Required scopes: (none needed — GitHub Models is public beta)
# Endpoint used: https://models.inference.ai.azure.com
# Model: gpt-4o-mini
GITHUB_TOKEN=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

# Set to true to activate the LLM parser (gpt-4o-mini).
# Set to false to use the regex fallback (SimpleResumeParser).
# Start with false, validate, then flip to true.
USE_LLM_PARSER=true

# ============================================================
# Email (optional)
# ============================================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
