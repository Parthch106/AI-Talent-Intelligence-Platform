# =========================
# DJANGO CORE
# =========================
DJANGO_ENV=development
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=django-insecure-change-this-key

# =========================
# DATABASE
# =========================
POSTGRES_DB=ai_talent_dev        # dev
# POSTGRES_DB=ai_talent_test       # testing
# POSTGRES_DB=ai_talent_prod       # production
POSTGRES_USER=ai_talent_user
POSTGRES_PASSWORD=dev_only_password
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
# ============================================================
# LLM Resume Parser (GitHub Models)
# ============================================================
# Get your token from: https://github.com/settings/tokens
# Use a CLASSIC token (starts with ghp_), not fine-grained
# NOTE: Use AI_TALENT_GITHUB_TOKEN to avoid conflicts with system GITHUB_TOKEN
AI_TALENT_GITHUB_TOKEN=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

# Legacy env var (may conflict with system token - use AI_TALENT_GITHUB_TOKEN instead)
# GITHUB_TOKEN=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

# Set to false to use simple parser
USE_LLM_PARSER=true

# =========================
# AUTH / SECURITY
# =========================
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440

# =========================
# FILE STORAGE
# =========================
MEDIA_ROOT=media
MEDIA_URL=/media/
